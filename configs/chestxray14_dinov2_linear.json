{
  "experiment_name": "dinov2_linear_weighted_bce",
  "seed": 42,
  "dataset": {
    "manifest_path": "artifacts/manifests/chestxray14_binary.csv",
    "image_size": 224,
    "batch_size": 16,
    "num_workers": 0
  },
  "model": {
    "name": "dinov2_linear",
    "pretrained": true,
    "freeze_backbone": true,
    "gradcam_target_layer": null,
    "local_weights_path": null
  },
  "training": {
    "device": "auto",
    "epochs": 8,
    "learning_rate": 0.0005,
    "weight_decay": 0.0001,
    "loss_name": "weighted_bce",
    "early_stopping_patience": 3,
    "save_every_epoch": false
  },
  "evaluation": {
    "threshold_metric": "f1",
    "save_predictions": true,
    "save_plots": true
  },
  "interpretation": {
    "num_examples": 8,
    "mask_fraction": 0.2,
    "curve_steps": 10
  },
  "output": {
    "root_dir": "artifacts/experiments"
  }
}
